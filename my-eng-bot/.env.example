# Ключ OpenRouter (https://openrouter.ai/). Задаётся на сервере, в браузере не вводится.
OPENROUTER_API_KEY=

# Ключ OpenAI. Используется, когда в меню выбран провайдер OpenAI (GPT‑4o mini).
OPENAI_API_KEY=

# Ключ xAI (Grok Voice) для звонка Engvo. Только серверный — без NEXT_PUBLIC_.
# Голос идёт через /api/realtime-session/xai-relay (сервер → api.x.ai), не из браузера напрямую.
# Локально: .env.local; на Vercel: Project Settings → Environment Variables (без HTTPS_PROXY на 127.0.0.1).
# Grok Voice локально: npm run dev:vercel (plain next dev не апгрейдит WebSocket relay).
XAI_API_KEY=

# Метки [engvo][timing] в консоли браузера: время до session.created / first_audio_delta и счётчик session.update.
# NEXT_PUBLIC_ENGVO_DEBUG_TIMING=1

# Локальный прокси VPN (Xray / V2Ray в режиме «Системный прокси»): Node (Next.js API + relay upstream) ходит к OpenAI/xAI,
# не через браузер. Если чат/translate с сервера не работает без VPN, задай тот же адрес, что в настройках VPN.
# На Vercel HTTPS_PROXY не задавать.
# HTTPS_PROXY=http://127.0.0.1:12334
# HTTP_PROXY=http://127.0.0.1:12334

# Кубки тем (🥇 + 5 практик). По умолчанию включены; отключить: NEXT_PUBLIC_FEATURE_PRACTICE_TOPIC_CUPS_V1=false
