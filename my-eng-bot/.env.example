# Ключ OpenRouter (https://openrouter.ai/). Задаётся на сервере, в браузере не вводится.
OPENROUTER_API_KEY=

# Ключ OpenAI. Используется, когда в меню выбран провайдер OpenAI (GPT‑4o mini).
OPENAI_API_KEY=

# Локальный прокси VPN (Xray / V2Ray в режиме «Системный прокси»): Node (Next.js API) ходит к OpenAI сам,
# не через браузер. Если регион/ключ ок в браузере, а /api/translate или чат с сервера — нет,
# задай тот же адрес, что в настройках VPN (пример: порт 12334 → 127.0.0.1:12334).
# HTTPS_PROXY=http://127.0.0.1:12334
# HTTP_PROXY=http://127.0.0.1:12334
