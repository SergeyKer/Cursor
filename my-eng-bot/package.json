{
  "name": "my-eng-bot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:icons": "tsx scripts/round-icon.ts",
    "build:necessary-words": "tsx scripts/build-necessary-words.ts",
    "export:necessary-words-txt": "tsx scripts/export-necessary-words-txt.ts",
    "build:header-robot": "node scripts/header-robot-match-bg.mjs",
    "build:footer-robot": "node scripts/footer-robot-process.mjs",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run && npm run check:cyrillic",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "check:cyrillic": "node scripts/check-cyrillic-integrity.mjs",
    "check:bundle:baseline": "node scripts/check-bundle-budget.mjs --baseline --save-baseline",
    "check:bundle": "node scripts/check-bundle-budget.mjs --enforce",
    "test:translation:smoke": "vitest run lib/translationLastRepeat.test.ts app/api/chat/route.translationStateRetention.test.ts lib/translationSayReconcile.test.ts app/api/chat/route.translationContext.test.ts app/api/chat/route.repeatFlow.test.ts"
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "server-only": "^0.0.1",
    "undici": "^7.24.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
